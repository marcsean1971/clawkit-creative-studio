{
  "name": "@clawkit/clawkit-creative-studio",
  "version": "0.1.2",
  "description": "ClawKit Creative Studio helps OpenClaw understand full websites and apps, then create launch-ready promotional briefs, image prompts, and video storyboards.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "openclaw.plugin.json",
    "skills",
    "README.md",
    "SECURITY.md",
    "docs"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit"
  },
  "keywords": [
    "openclaw",
    "openclaw-plugin",
    "clawkit",
    "creative-studio",
    "website-to-marketing",
    "app-promo",
    "product-launch",
    "lovable",
    "screenshots",
    "video-storyboard"
  ],
  "license": "MIT",
  "dependencies": {
    "@sinclair/typebox": "^0.34.49",
    "openclaw": "^2026.4.29"
  },
  "devDependencies": {
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=22"
  },
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ],
    "compat": {
      "pluginApi": ">=2026.3.24-beta.2",
      "minGatewayVersion": "2026.3.24-beta.2"
    },
    "build": {
      "openclawVersion": "2026.4.29",
      "pluginSdkVersion": "2026.4.29"
    }
  }
}
